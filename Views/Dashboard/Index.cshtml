@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    ViewData["BreadcrumbTitle"] = "Dashboard";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Dashboard</h1>
        <p class="page-subtitle">Welcome back! Here's what's happening with your inventory.</p>
    </div>
</div>

<!-- Summary Cards -->
<div class="row g-4 mb-4">
    <div class="col-12 col-sm-6 col-xl-4">
        <div class="stat-card stat-card--blue">
            <div class="stat-card__icon">
                <i class="bi bi-archive-fill"></i>
            </div>
            <div class="stat-card__content">
                <div class="stat-card__value">@Model.TotalProducts</div>
                <div class="stat-card__label">Total Products</div>
            </div>
            <div class="stat-card__footer">
                <a asp-controller="Products" asp-action="Index" class="stretched-link">View All <i class="bi bi-arrow-right ms-1"></i></a>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-xl-4">
        <div class="stat-card stat-card--blue">
            <div class="stat-card__icon">
                <i class="bi bi-people-fill"></i>
            </div>
            <div class="stat-card__content">
                <div class="stat-card__value">@Model.TotalUsers</div>
                <div class="stat-card__label">Registered Users</div>
            </div>
            <div class="stat-card__footer">
                <span>Active system users</span>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-xl-4">
        <div class="stat-card stat-card--blue">
            <div class="stat-card__icon">
                <i class="bi bi-tag-fill"></i>
            </div>
            <div class="stat-card__content">
                <div class="stat-card__value">@Model.TotalCategories</div>
                <div class="stat-card__label">Categories</div>
            </div>
            <div class="stat-card__footer">
                <span>Unique product categories</span>
            </div>
        </div>
    </div>
</div>

<!-- Latest Products Table -->
<div class="card shadow-sm">
    <div class="card-header d-flex align-items-center justify-content-between">
        <div>
            <h5 class="card-title mb-0"><i class="bi bi-clock-history me-2 text-primary"></i>Latest Products</h5>
            <small class="text-muted">5 most recently added products</small>
        </div>
        <a asp-controller="Products" asp-action="Index" class="btn btn-sm btn-outline-primary">
            <i class="bi bi-grid me-1"></i> View All
        </a>
    </div>
    <div class="card-body p-0">
        @if (!Model.LatestProducts.Any())
        {
            <div class="empty-state py-5">
                <i class="bi bi-inbox display-4 text-muted"></i>
                <p class="mt-3 text-muted">No products yet. Add your first product!</p>
                @if (User.IsInRole("Admin"))
                {
                    <a asp-controller="Products" asp-action="Create" class="btn btn-primary mt-2">
                        <i class="bi bi-plus-lg me-1"></i> Add Product
                    </a>
                }
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Product Name</th>
                            <th>Category</th>
                            <th class="text-end">Price</th>
                            <th>Date Added</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var product in Model.LatestProducts)
                        {
                            <tr>
                                <td><span class="text-muted">@product.Id</span></td>
                                <td><strong>@product.Name</strong></td>
                                <td><span class="badge bg-secondary-subtle text-secondary">@product.Category</span></td>
                                <td class="text-end fw-semibold text-success">₱@product.Price.ToString("N2")</td>
                                <td class="text-muted small">@product.DateAdded.ToString("MMM dd, yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
