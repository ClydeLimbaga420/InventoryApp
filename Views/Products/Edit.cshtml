@model Product
@{
    ViewData["Title"] = "Edit Product";
    ViewData["BreadcrumbTitle"] = "Edit Product";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Edit Product</h1>
        <p class="page-subtitle">Update the details for "@Model.Name"</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Back to Products
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-12 col-lg-7">
        <div class="card shadow-sm">
            <div class="card-header">
                <h6 class="mb-0"><i class="bi bi-pencil-square me-2 text-warning"></i>Edit Product Information</h6>
            </div>
            <div class="card-body">
                <form asp-action="Edit">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="DateAdded" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small" role="alert"></div>

                    <div class="mb-4">
                        <label asp-for="Name" class="form-label fw-semibold"></label>
                        <input asp-for="Name" class="form-control form-control-lg" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Price" class="form-label fw-semibold"></label>
                        <div class="input-group input-group-lg">
                            <span class="input-group-text">₱</span>
                            <input asp-for="Price" class="form-control" type="number" step="0.01" min="1" max="100000" />
                        </div>
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Category" class="form-label fw-semibold"></label>
                        <input asp-for="Category" class="form-control form-control-lg" list="categoryList" />
                        <datalist id="categoryList">
                            <option value="Electronics"></option>
                            <option value="Clothing"></option>
                            <option value="Food & Beverage"></option>
                            <option value="Furniture"></option>
                            <option value="Sports"></option>
                            <option value="Books"></option>
                            <option value="Tools"></option>
                            <option value="Health & Beauty"></option>
                        </datalist>
                        <span asp-validation-for="Category" class="text-danger small"></span>
                    </div>

                    <div class="p-3 bg-light rounded mb-4 small text-muted">
                        <i class="bi bi-calendar3 me-2"></i>
                        Originally added: <strong>@Model.DateAdded.ToString("MMMM dd, yyyy 'at' hh:mm tt")</strong>
                    </div>

                    <div class="d-flex gap-3">
                        <button type="submit" class="btn btn-warning btn-lg px-5">
                            <i class="bi bi-check-lg me-2"></i>Update Product
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary btn-lg">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
