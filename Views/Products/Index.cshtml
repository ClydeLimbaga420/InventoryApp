@model IEnumerable<Product>
@{
    ViewData["Title"] = "Products";
    ViewData["BreadcrumbTitle"] = "Products";
    var search = ViewBag.Search as string ?? "";
    var category = ViewBag.Category as string ?? "";
    var sortPrice = ViewBag.SortPrice as string ?? "";
    var categories = ViewBag.Categories as List<string> ?? new List<string>();
}

<div class="page-header">
    <div>
        <h1 class="page-title">Product Inventory</h1>
        <p class="page-subtitle">Manage and track your products</p>
    </div>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary btn-action">
            <i class="bi bi-plus-lg me-1"></i> Add Product
        </a>
    }
</div>

<!-- Search & Filter Bar -->
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form method="get" asp-action="Index" class="row g-3 align-items-end">
            <div class="col-12 col-md-5">
                <label class="form-label small fw-semibold text-muted text-uppercase">Search</label>
                <div class="input-group">
                    <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" name="search" value="@search"
                           class="form-control" placeholder="Search by product name..." />
                </div>
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label small fw-semibold text-muted text-uppercase">Category</label>
                <select name="category" class="form-select">
                    <option value="">All Categories</option>
                    @foreach (var cat in categories)
                    {
                        <option value="@cat" selected="@(category == cat)">@cat</option>
                    }
                </select>
            </div>
            <div class="col-12 col-md-2">
                <label class="form-label small fw-semibold text-muted text-uppercase">Sort by Price</label>
                <select name="sortPrice" class="form-select">
                    <option value="">Latest First</option>
                    <option value="asc" selected="@(sortPrice == "asc")">Price: Low → High</option>
                    <option value="desc" selected="@(sortPrice == "desc")">Price: High → Low</option>
                </select>
            </div>
            <div class="col-12 col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-grow-1">
                    <i class="bi bi-funnel me-1"></i> Filter
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary" title="Reset">
                    <i class="bi bi-x-circle"></i>
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Results Info -->
@if (!string.IsNullOrEmpty(search) || !string.IsNullOrEmpty(category))
{
    <div class="d-flex align-items-center mb-3 text-muted small">
        <i class="bi bi-info-circle me-2"></i>
        Showing <strong class="mx-1">@Model.Count()</strong> result(s)
        @if (!string.IsNullOrEmpty(search)) { <span class="ms-1">for "<em>@search</em>"</span> }
        @if (!string.IsNullOrEmpty(category)) { <span class="ms-1">in <em>@category</em></span> }
    </div>
}

<!-- Products Table -->
<div class="card shadow-sm">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="empty-state py-5">
                <i class="bi bi-search display-4 text-muted"></i>
                <p class="mt-3 text-muted">No products found matching your criteria.</p>
                <a asp-action="Index" class="btn btn-outline-secondary mt-1">Clear Filters</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th width="60">#</th>
                            <th>Product Name</th>
                            <th>Category</th>
                            <th class="text-end" width="140">Price (₱)</th>
                            <th width="140">Date Added</th>
                            @if (User.IsInRole("Admin"))
                            {
                                <th class="text-center" width="160">Actions</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-muted">@item.Id</td>
                                <td>
                                    <div class="fw-semibold">@item.Name</div>
                                </td>
                                <td>
                                    <span class="badge rounded-pill bg-primary-subtle text-primary px-3 py-1">
                                        @item.Category
                                    </span>
                                </td>
                                <td class="text-end fw-bold text-success">
                                    ₱@item.Price.ToString("N2")
                                </td>
                                <td class="text-muted small">
                                    @item.DateAdded.ToString("MMM dd, yyyy")
                                </td>
                                @if (User.IsInRole("Admin"))
                                {
                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-2">
                                            <a asp-action="Edit" asp-route-id="@item.Id"
                                               class="btn btn-sm btn-warning" title="Edit">
                                                <i class="bi bi-pencil-fill"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.Id"
                                               class="btn btn-sm btn-danger" title="Delete">
                                                <i class="bi bi-trash-fill"></i>
                                            </a>
                                        </div>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="px-4 py-3 border-top text-muted small">
                Total: <strong>@Model.Count()</strong> product(s)
            </div>
        }
    </div>
</div>
